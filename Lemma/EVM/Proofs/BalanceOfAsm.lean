import Lemma.EVM.Asm
import Lemma.EVM.Codegen.Getters

/-!
# Assembly Lemma: balanceOfCode

Proves that `assemble balanceOfCode` produces the exact byte sequence
used in the execution correctness proof.
-/

namespace EVM

theorem balanceOf_asm :
    assemble Codegen.balanceOfCode =
    some [0x60, 0x04, 0x35, 0x60, 0x00, 0x52, 0x60, 0x01, 0x60, 0x20, 0x52,
          0x60, 0x40, 0x60, 0x00, 0x20, 0x54, 0x60, 0x00, 0x52, 0x60, 0x20,
          0x60, 0x00, 0xf3] := by
  native_decide

end EVM
