import Lemma.EVM.Asm
import Lemma.EVM.Codegen.Transfer

/-!
# Assembly Lemma: transferCode

Proves that `assemble transferCode` produces the exact 60-byte sequence
used in the execution correctness proof.
-/

namespace EVM

theorem transfer_asm :
    assemble Codegen.transferCode =
    some [0x33, 0x60, 0x04, 0x35, 0x60, 0x24, 0x35, 0x82, 0x60, 0x00,
          0x52, 0x60, 0x01, 0x60, 0x20, 0x52, 0x60, 0x40, 0x60, 0x00,
          0x20, 0x80, 0x54, 0x82, 0x81, 0x10, 0x15, 0x60, 0x23, 0x57,
          0x60, 0x00, 0x60, 0x00, 0xfd, 0x5b, 0x82, 0x90, 0x03, 0x90,
          0x55, 0x81, 0x60, 0x00, 0x52, 0x60, 0x40, 0x60, 0x00, 0x20,
          0x80, 0x54, 0x82, 0x01, 0x90, 0x55, 0x50, 0x50, 0x50, 0x00] := by
  native_decide

end EVM
