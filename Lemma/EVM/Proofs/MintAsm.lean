import Lemma.EVM.Asm
import Lemma.EVM.Codegen.Mint

/-!
# Assembly Lemma: mintCode

Proves that `assemble mintCode` produces the exact byte sequence
used in the execution correctness proof.
-/

namespace EVM

theorem mint_asm :
    assemble Codegen.mintCode =
    some [0x60, 0x04, 0x35, 0x60, 0x24, 0x35, 0x81, 0x60, 0x00, 0x52,
          0x60, 0x01, 0x60, 0x20, 0x52, 0x60, 0x40, 0x60, 0x00, 0x20,
          0x80, 0x54, 0x82, 0x01, 0x90, 0x55, 0x60, 0x00, 0x54, 0x01,
          0x60, 0x00, 0x55, 0x50, 0x00] := by
  native_decide

end EVM
